// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum JobSource {
  LINKEDIN
  INDEED
  GLASSDOOR
  STARTUPJOBS
  JOBSTACK
}

enum ApplicationStatus {
  PENDING
  APPLIED
  REJECTED
  INTERVIEW
  FAILED
}

enum SiteName {
  LINKEDIN
  INDEED
}

model UserProfile {
  id                  String   @id @default(cuid())
  name                String
  email               String
  phone               String?
  cvPath              String?
  linkedInUrl         String?
  githubUrl           String?
  coverLetterLanguage String   @default("English")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model JobPosting {
  id           String        @id @default(cuid())
  title        String
  company      String
  location     String?
  description  String        @db.Text
  sourceUrl    String        @unique
  source       JobSource
  salary       String?
  postedAt     DateTime?
  scrapedAt    DateTime      @default(now())
  embedding    Json?
  favourited   Boolean       @default(false)
  applications Application[]
  coverLetters CoverLetter[]
}

model Application {
  id            String            @id @default(cuid())
  jobId         String
  job           JobPosting        @relation(fields: [jobId], references: [id])
  status        ApplicationStatus @default(PENDING)
  appliedAt     DateTime?
  errorMessage  String?           @db.Text
  coverLetterId String?
  coverLetter   CoverLetter?      @relation(fields: [coverLetterId], references: [id])
  interview     Interview?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

model CoverLetter {
  id            String        @id @default(cuid())
  jobId         String
  job           JobPosting    @relation(fields: [jobId], references: [id])
  content       String        @db.Text
  generatedByAI Boolean       @default(false)
  createdAt     DateTime      @default(now())
  applications  Application[]
}

model Interview {
  id              String      @id @default(cuid())
  applicationId   String      @unique
  application     Application @relation(fields: [applicationId], references: [id])
  scheduledAt     DateTime
  durationMinutes Int         @default(60)
  timezone        String      @default("UTC")
  notes           String?     @db.Text
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model SiteCredential {
  id                String   @id @default(cuid())
  site              SiteName @unique
  username          String
  encryptedPassword String
  cookieJson        String?  @db.Text
  updatedAt         DateTime @updatedAt
}
